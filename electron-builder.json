{
  "appId": "com.dpineda.flashback",
  "productName": "Flashback",
  "files": ["dist-react", "src/api", "src/electron", "src/mcp"],
  "icon": "flashback.ico",
  "extraResources": ["flashback.ico", "flashback.png"],
  "publish": [
    {
      "provider": "github",
      "owner": "WeirdCatAFK",
      "repo": "Flashback"
    }
  ],
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility",
    "icon": "flashback.png"
  },
  "win": {
    "target": ["nsis"]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  }
}
