{
  "name": "flashback",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "src/electron/main.js",
  "description": "The memorization app",
  "scripts": {

    "dev": "npm-run-all --parallel dev:react dev:electron",
    "dev:react": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev:api": "nodemon api.js",
    "dev:web": "npm-run-all --parallel dev:react dev:api",
    "react:build": "vite build",
    "dist:mac": "npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux --x64",
    "build": "vite build",
    "lint": "eslint .",
    "electron": "electron ."

  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WeirdCatAFK/Flashback.git"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "d3": "^7.9.0",
    "highlight.js": "^11.10.0",
    "install": "^0.13.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.456.0",
    "markdown-it": "^14.1.0",
    "npm": "^10.9.0",
    "quill": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-quill": "^2.0.0"
  },
  "author": "Daniel Pineda Torres",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/WeirdCatAFK/Flashback/issues"
  },
  "homepage": "https://github.com/WeirdCatAFK/Flashback#readme",
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "express": "^4.21.0",
    "globals": "^15.11.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.1.7",
    "npm-run-all": "^4.1.5",
    "sqlite3": "^5.1.7",
    "vite": "^5.4.9"
  }
}